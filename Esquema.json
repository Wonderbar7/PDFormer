{
  "app_metadata": {
    "name": "PDFormer",
    "description": "Editor de Formularios PDF interactivo con soporte para campos editables, firmas y tipex.",
    "default_window_size": {
      "width": 1280,
      "height": 800
    }
  },
  "design_system": {
    "theme": "Material Design Lite / Custom",
    "typography": {
      "primary_font": "\"Segoe UI\", Roboto, sans-serif",
      "font_sizes": {
        "normal": "13px",
        "toolbar_buttons": "12px",
        "canvas_text": "11px"
      }
    },
    "colors": {
      "background_main": "#FDFBFF",
      "background_toolbar": "#FEF7FF",
      "background_canvas": "#F0EBF4",
      "border_light": "#E7E0EC",
      "border_dark": "#CAC4D0",
      "text_primary": "#49454F",
      "text_accent": "#21005D",
      "accent_primary": "#6750A4",
      "accent_hover": "#EADDFF",
      "accent_pressed": "#D0BCFF",
      "guide_lines": "#E91E63"
    },
    "shapes": {
      "button_border_radius": "6px",
      "menu_border_radius": "8px",
      "scrollbar_radius": "6px"
    }
  },
  "layout_structure": {
    "top_area": {
      "menu_bar": [
        {
          "label": "Archivo",
          "actions": ["Nuevo PDF (Ctrl+N)", "Abrir PDF (Ctrl+O)", "Guardar (Ctrl+S)", "Guardar como... (Ctrl+Shift+S)", "Salir (Ctrl+Q)"]
        },
        {
          "label": "Edición",
          "actions": ["Deshacer (Ctrl+Z)", "Rehacer (Ctrl+Y)", "Copiar (Ctrl+C)", "Pegar (Ctrl+V)", "Eliminar (Del)"]
        },
        {
          "label": "Páginas",
          "actions": ["Añadir Página", "Borrar Página"]
        },
        {
          "label": "Herramientas",
          "actions": ["Cursor", "Imán (Guías)", "Texto Libre", "Típex", "Texto", "Multilínea", "Checkbox", "Desplegable", "Firma"]
        }
      ],
      "top_toolbars": [
        {
          "name": "Edición",
          "buttons": ["Deshacer", "Rehacer", "Copiar", "Pegar", "Eliminar"]
        },
        {
          "name": "Páginas",
          "buttons": ["Añadir Página", "Borrar Página"]
        }
      ]
    },
    "left_area": {
      "sidebar_toolbar": {
        "name": "Herramientas",
        "width": "110px",
        "tools": [
          { "id": "cursor", "icon": "👆", "label": "Cursor", "type": "selector" },
          { "id": "snap", "icon": "🧲", "label": "Imán (Guías)", "type": "toggle", "default_state": "active" },
          { "id": "static_text", "icon": "🔤", "label": "Texto Libre", "type": "action" },
          { "id": "whiteout", "icon": "⬜", "label": "Típex", "type": "action" },
          { "id": "text", "icon": "📝", "label": "Texto", "type": "action" },
          { "id": "textarea", "icon": "📑", "label": "Multilínea", "type": "action" },
          { "id": "checkbox", "icon": "☑️", "label": "Checkbox", "type": "action" },
          { "id": "dropdown", "icon": "🔽", "label": "Desplegable", "type": "action" },
          { "id": "signature", "icon": "🖋️", "label": "Firma", "type": "action" }
        ]
      }
    },
    "center_area": {
      "workspace": {
        "type": "PDF_Canvas",
        "features": [
          "Drag & Drop files",
          "Zoom con Ctrl + Rueda del ratón",
          "Selección con Rubber Band (Caja de selección transparente)",
          "Scroll vertical infinito con gap de 30px entre páginas"
        ]
      }
    },
    "bottom_area": {
      "status_bar": {
        "left_content": "Status_Label (Muestra mensajes de éxito, error o instrucciones de la herramienta activa)",
        "right_content": {
          "type": "Pagination_Controls",
          "elements": ["Botón Página Anterior (⬆️)", "Label 'Página X / Y'", "Botón Página Siguiente (⬇️)"]
        }
      }
    }
  },
  "interactive_elements": {
    "canvas_items": [
      {
        "type": "whiteout",
        "fill": "rgba(255, 255, 255, 1)",
        "border_default": "1.5px solid #21005D",
        "border_hidden": "1px dashed rgba(150, 150, 150, 0.6)"
      },
      {
        "type": "static_text",
        "fill": "rgba(255, 255, 255, 0)",
        "border_default": "1.5px solid #21005D",
        "border_hidden": "1px dashed rgba(150, 150, 150, 0.6)"
      },
      {
        "type": "signature",
        "fill": "rgba(255, 235, 156, 0.62)",
        "border_default": "1.5px solid #21005D",
        "border_hidden": "none"
      },
      {
        "type": "form_fields (text, checkbox, etc.)",
        "fill": "rgba(234, 221, 255, 0.62)",
        "border_default": "1.5px solid #21005D",
        "border_hidden": "none"
      }
    ],
    "item_behavior": {
      "resize_handles": "8 puntos en los bordes y esquinas, color #6750A4 con borde blanco de 1.5px",
      "snapping": "Atracción magnética (threshold 5px) a centros y bordes de otros elementos si el Imán está activo.",
      "duplication": "Arrastrar con Shift pulsado clona el elemento."
    },
    "context_menu": {
      "trigger": "Clic derecho sobre un elemento",
      "options": [
        "🚫 Quitar borde / 🔲 Poner borde",
        "✏️ Editar Texto (solo para Texto Libre)",
        "📏 Definir tamaño... (Abre modal para Width x Height en px)"
      ]
    }
  },
  "core_functionality": {
    "undo_redo_system": "Soporta comandos de Añadir, Eliminar, Mover/Redimensionar, Alternar Borde y Cambiar Texto.",
    "pdf_export": "Usa PyMuPDF para aplanar el Tipex/Texto Estático y convertir el resto en Widget Annotations interactivas estándar de PDF.",
    "page_management": "Añadir página en blanco mueve dinámicamente los elementos de la vista; Eliminar página limpia los elementos asociados."
  }
}